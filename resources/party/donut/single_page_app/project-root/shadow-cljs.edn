;; shadow-cljs configuration
{:deps           {:aliases [:cljs :dev :framework-dev]}
 :dev-http       {3000 {:roots     ["resources/public" "frontend-target/dev/public"]
                        :proxy-url "http://localhost:3010"
                        :push-state/headers {"Cross-Origin-Opener-Policy" "same-origin-allow-popups"}}}

 :builds {:dev
          {:target           :browser
           :output-dir       "frontend-target/dev/public/js"
           :asset-path       "/js"
           :compiler-options {:optimizations           :none
                              :source-map              true
                              :source-map-detail-level :all
                              :closure-defines         {re-frame.trace.trace-enabled?        true
                                                        day8.re-frame.tracing.trace-enabled? true}
                              ;; this is specifically for the warning in loom/alg_generic:494.
                              :warnings                {:invalid-arithmetic false}}
           :build-hooks      [(donut.frontend.routes/write-frontend-routes-hook {{top/ns}}.{{main/ns}}.frontend.frontend-routes/routes)]

           :modules
           {:main {:entries [{{top/ns}}.{{main/ns}}.frontend.core]
                   :init-fn {{top/ns}}.{{main/ns}}.frontend.core/init}}

           ;; start a development http server on http://localhost:3000
           :devtools
           {:preloads        [day8.re-frame-10x.preload
                              devtools.preload]
            :hud             #{:errors}
            :reload-strategy :full
            :ignore-warnings true}}

          ;; production build, used by `npm run release` (the :dev build
          ;; pins :optimizations :none and can't be released)
          :app
          {:target           :browser
           :output-dir       "frontend-target/app/public/js"
           :asset-path       "/js"
           :compiler-options {:warnings {:invalid-arithmetic false}}
           :modules
           {:main {:entries [{{top/ns}}.{{main/ns}}.frontend.core]
                   :init-fn {{top/ns}}.{{main/ns}}.frontend.core/init}}}}}
